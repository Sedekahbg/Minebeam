# ── Required ──────────────────────────────
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Telegram Notifications (Required) ────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id_from_userinfobot

# ── Optional (with defaults) ──────────────
# TOTAL_ROUNDS=0                    # 0 = unlimited 24/7 mode
# BLOCKS_PER_DEPLOY=5               # 1-25 blocks per round
# ETH_PER_ROUND=0.0000125           # ETH per round (min 0.0000025 × blocks)
# BLOCK_STRATEGY=least_crowded      # least_crowded or random
# DEPLOY_AT_SECONDS_LEFT=15         # Deploy X seconds before round ends
# CLAIM_EVERY_N_ROUNDS=5            # Claim rewards every N rounds
# CLAIM_ETH_MIN=0.0005              # Min pending ETH to trigger claim
# CLAIM_BEAN_MIN=1.0                # Min pending BEAN to trigger claim
# HOLD_BEAN=false                   # true = hold BEAN for roasting bonus
# MIN_BALANCE_ETH=0.0005            # Min ETH balance to keep running
# BASE_RPC_URL=https://mainnet.base.org  # Base RPC (use Alchemy/Infura for speed)
